## Soluzione completa commentata

```python
# =============================================================
#  analisi_discorsi.py  –  SOLUZIONE DOCENTE
# =============================================================

import matplotlib.pyplot as plt
import numpy as np

# ---- TESTI ----

MLK_SPEECH = """
I have a dream that one day this nation will rise up
and live out the true meaning of its creed.
We hold these truths to be self-evident,
that all men are created equal.
I have a dream that one day on the red hills of Georgia,
the sons of former slaves and the sons of former slave owners
will be able to sit down together at the table of brotherhood.
I have a dream that one day even the state of Mississippi,
a state sweltering with the heat of injustice,
will be transformed into an oasis of freedom and justice.
I have a dream that my four little children will one day live in a nation
where they will not be judged by the color of their skin
but by the content of their character.
I have a dream today.
Let freedom ring. Let freedom ring from every mountainside.
Free at last, free at last, thank God Almighty, we are free at last.
"""

JOBS_SPEECH = """
Today I want to tell you three stories from my life.
The first story is about connecting the dots.
I dropped out of Reed College after the first six months.
I had no idea what I wanted to do with my life.
But I decided to drop in on a calligraphy class.
I learned about serif and sans serif typefaces,
about varying the amount of space between different letter combinations.
It was beautiful, historical, artistically subtle.
None of this had even a hope of any practical application in my life.
But ten years later, when we were designing the first Macintosh computer,
it all came back to me.
The Mac was the first computer with beautiful typography.
You cannot connect the dots looking forward.
You can only connect them looking backwards.
So you have to trust that the dots will somehow connect in your future.
Stay hungry. Stay foolish.
"""

# ---- STOP WORDS (usate nella versione bonus) ----

STOP_WORDS = [
    "the", "a", "an", "of", "to", "and", "i", "in", "that",
    "is", "it", "with", "you", "for", "was", "be", "are",
    "have", "will", "on", "at", "by", "my", "we", "not",
    "this", "but", "from", "as", "all", "so", "had", "do",
    "they", "their", "them", "up", "out", "its", "one", "no"
]


# ---- FASE 1 ----

def conta_parole(testo, filtra_stop=False):
    """
    Riceve una stringa e restituisce due liste parallele:
      parole[]   -> parole uniche trovate nel testo
      conteggi[] -> quante volte compare ognuna

    Parametro opzionale filtra_stop: se True, esclude le STOP_WORDS.
    """

    # 1. Minuscolo
    testo = testo.lower()

    # 2. Rimuovi punteggiatura
    for segno in [",", ".", "!", "?", ";", ":", '"', "'"]:
        testo = testo.replace(segno, "")

    # 3. Dividi in lista di parole
    parole_testo = testo.split()

    parole   = []
    conteggi = []

    # 4. Scansione
    for parola in parole_testo:

        # BONUS: salta le stop words se richiesto
        if filtra_stop and parola in STOP_WORDS:
            continue

        if parola in parole:
            indice = parole.index(parola)
            conteggi[indice] += 1
        else:
            parole.append(parola)
            conteggi.append(1)

    return parole, conteggi


# ---- FASE 2 ----

def frequenze_relative(conteggi):
    """
    Converte una lista di conteggi interi in frequenze relative (float).
    La somma di tutti gli elementi del risultato vale 1.0.
    """
    totale = sum(conteggi)
    # List comprehension: equivalente a un ciclo for che costruisce una lista
    return [c / totale for c in conteggi]


# ---- FASE 3 ----

def top_n(parole, conteggi, n):
    """
    Ordina le due liste parallele in ordine decrescente di conteggio
    (selection sort) e restituisce solo i primi n elementi.

    IMPORTANTE: il doppio scambio mantiene la sincronizzazione tra le liste.
    Se scambio conteggi[i] con conteggi[max_idx], devo scambiare anche
    parole[i] con parole[max_idx], altrimenti i dati si disallineano.
    """
    for i in range(len(conteggi)):
        max_idx = i
        for j in range(i + 1, len(conteggi)):
            if conteggi[j] > conteggi[max_idx]:
                max_idx = j
        # Doppio scambio — sintassi Python con tupla
        conteggi[i], conteggi[max_idx] = conteggi[max_idx], conteggi[i]
        parole[i],   parole[max_idx]   = parole[max_idx],   parole[i]

    return parole[:n], conteggi[:n]


# ---- FASE 4 ----

def grafico_confronto(parole1, freq1, parole2, freq2, nome1, nome2, n=10):
    """
    Disegna un bar chart raggruppato: per ogni parola (asse X) mostra
    due barre affiancate, una per oratore, con la frequenza relativa (asse Y).

    np.arange(n) produce l'array [0, 1, 2, ..., n-1] che rappresenta
    le posizioni delle etichette sull'asse X.
    Le due serie di barre vengono spostate di ±larghezza/2 rispetto al centro.
    """
    x = np.arange(n)
    larghezza = 0.35

    fig, ax = plt.subplots(figsize=(12, 6))

    ax.bar(x - larghezza / 2, freq1[:n], larghezza, label=nome1, color="steelblue")
    ax.bar(x + larghezza / 2, freq2[:n], larghezza, label=nome2, color="tomato")

    ax.set_xlabel("Parole")
    ax.set_ylabel("Frequenza relativa")
    ax.set_title(f"Top {n} parole più usate: {nome1} vs {nome2}")
    ax.set_xticks(x)
    ax.set_xticklabels(parole1[:n], rotation=45, ha="right")
    ax.legend()
    plt.tight_layout()
    plt.show()


# ---- PROGRAMMA PRINCIPALE ----

def main():
    # Versione base (senza filtro stop words)
    parole_mlk,  cont_mlk  = conta_parole(MLK_SPEECH)
    parole_jobs, cont_jobs = conta_parole(JOBS_SPEECH)

    freq_mlk  = frequenze_relative(cont_mlk)
    freq_jobs = frequenze_relative(cont_jobs)

    top_p_mlk,  top_f_mlk  = top_n(parole_mlk,  freq_mlk,  10)
    top_p_jobs, top_f_jobs = top_n(parole_jobs, freq_jobs, 10)

    print("=== TOP 10 – MLK ===")
    for i in range(10):
        print(f"  {top_p_mlk[i]:15s}  {top_f_mlk[i]:.3f}")

    print("\n=== TOP 10 – JOBS ===")
    for i in range(10):
        print(f"  {top_p_jobs[i]:15s}  {top_f_jobs[i]:.3f}")

    grafico_confronto(top_p_mlk, top_f_mlk, top_p_jobs, top_f_jobs, "MLK", "Jobs")

    # Versione bonus (con filtro stop words)
    parole_mlk2,  cont_mlk2  = conta_parole(MLK_SPEECH,  filtra_stop=True)
    parole_jobs2, cont_jobs2 = conta_parole(JOBS_SPEECH, filtra_stop=True)

    freq_mlk2  = frequenze_relative(cont_mlk2)
    freq_jobs2 = frequenze_relative(cont_jobs2)

    top_p_mlk2,  top_f_mlk2  = top_n(parole_mlk2,  freq_mlk2,  10)
    top_p_jobs2, top_f_jobs2 = top_n(parole_jobs2, freq_jobs2, 10)

    grafico_confronto(
        top_p_mlk2, top_f_mlk2, top_p_jobs2, top_f_jobs2,
        "MLK (no stop)", "Jobs (no stop)"
    )


if __name__ == "__main__":
    main()
```

